---
import { t, getLanguage } from '@/lib/i18n';
import Icon from '@/components/icons/phosphor.astro';
import DESKTOP_RELEASES from '@/data/desktopReleases';

// Locale-aware internal links (e.g. /changelog/ vs /zh/changelog/).
const lang = getLanguage();
const localePrefix = lang === 'en' ? '' : `/${lang}`;
const changelogHref = `${localePrefix}/changelog/`;

// Latest release drives BOTH the download-button URLs and the
// "What's new in v{version}" callout.  release-bump.mjs prepends
// the new entry to desktopReleases.ts and updates DOWNLOAD_VERSION
// in one shot, so these two stay in sync automatically.
const DOWNLOAD_VERSION = '1.6.2';
const LATEST = DESKTOP_RELEASES[0];
const latestHighlights = LATEST.changes.filter(c => c.kind === 'highlight').slice(0, 3);
const RELEASES_BASE = `https://github.com/microblue/myclaw-desktop-releases/releases/download/v${DOWNLOAD_VERSION}`;

const features = [
    { icon: 'clock',                title: t('landing.zeroConfig'),         description: t('go.zeroConfigDescription') },
    { icon: 'lock',                 title: t('landing.ownedData'),          description: t('go.ownedDataDescription') },
    { icon: 'terminal',             title: t('landing.fullSshAccess'),      description: t('go.terminalAccessDescription') },
    { icon: 'credit-card',          title: t('go.simplePricing'),           description: t('go.simplePricingDescription') },
    { icon: 'link',                 title: t('go.localDomain'),             description: t('go.localDomainDescription') },
    { icon: 'shield-check',         title: t('landing.secure'),             description: t('go.secureDescription') },
    { icon: 'git-branch',           title: t('landing.autoUpdates'),        description: t('landing.autoUpdatesDescription') },
    { icon: 'sliders-horizontal',   title: t('landing.openclawControl'),    description: t('landing.openclawControlDescription') },
    { icon: 'puzzle-piece',         title: t('landing.skillsMarketplace'),  description: t('landing.skillsMarketplaceDescription') },
    { icon: 'chat-circle-dots',     title: t('landing.directChat'),         description: t('landing.directChatDescription') },
    { icon: 'users-three',          title: t('landing.multipleAgents'),     description: t('landing.multipleAgentsDescription') },
] as const;

const comparisonRows = [
    { us: t('go.comparisonLocalUs'),    others: t('go.comparisonLocalOthers') },
    { us: t('go.comparisonPricingUs'),  others: t('go.comparisonPricingOthers') },
    { us: t('go.comparisonDataUs'),     others: t('go.comparisonDataOthers') },
    { us: t('go.comparisonSetupUs'),    others: t('go.comparisonSetupOthers') },
    { us: t('go.comparisonUpdatesUs'),  others: t('go.comparisonUpdatesOthers') },
    { us: t('go.comparisonAgentsUs'),   others: t('go.comparisonAgentsOthers') },
];

const faqs = [
    { question: t('go.faq1Question'), answer: t('go.faq1Answer') },
    { question: t('go.faq2Question'), answer: t('go.faq2Answer') },
    { question: t('go.faq3Question'), answer: t('go.faq3Answer') },
    { question: t('go.faq4Question'), answer: t('go.faq4Answer') },
    { question: t('go.faq5Question'), answer: t('go.faq5Answer') },
    { question: t('go.faq6Question'), answer: t('go.faq6Answer') },
];

const downloads = [
    { platform: 'Windows',      sublabel: 'x64 · .exe Installer',      url: `${RELEASES_BASE}/MyClaw.One-${DOWNLOAD_VERSION}-win-x64.exe`,            featured: true },
    { platform: 'Linux',        sublabel: 'x64 · AppImage',            url: `${RELEASES_BASE}/MyClaw.One-${DOWNLOAD_VERSION}-linux-x86_64.AppImage` },
    { platform: 'Linux',        sublabel: 'x64 · Debian / Ubuntu',     url: `${RELEASES_BASE}/MyClaw.One-${DOWNLOAD_VERSION}-linux-amd64.deb` },
    { platform: 'Linux',        sublabel: 'x64 · RPM',                 url: `${RELEASES_BASE}/MyClaw.One-${DOWNLOAD_VERSION}-linux-x86_64.rpm` },
    { platform: 'Linux ARM64',  sublabel: 'arm64 · AppImage',          url: `${RELEASES_BASE}/MyClaw.One-${DOWNLOAD_VERSION}-linux-arm64.AppImage` },
    { platform: 'Linux ARM64',  sublabel: 'arm64 · Debian / Ubuntu',   url: `${RELEASES_BASE}/MyClaw.One-${DOWNLOAD_VERSION}-linux-arm64.deb` },
];

const stats = [
    { value: `v${DOWNLOAD_VERSION}`, label: t('go.statsLatest') },
    { value: t('go.statsWindows'),    label: t('go.statsPlatformWindows') },
    { value: t('go.statsLinux'),      label: t('go.statsPlatformLinux') },
    { value: t('go.statsZero'),       label: t('go.statsZeroConfig') },
];

const currentVersionText = t('go.currentVersion', { version: DOWNLOAD_VERSION });
---
<!-- Ambient background gradient + grid, fixed to viewport -->
<div class="landing-gradient pointer-events-none fixed inset-0 z-0"></div>

<!-- Hero -->
<section class="relative overflow-hidden px-6 pt-24 pb-16">
    <div class="landing-grid pointer-events-none absolute inset-0"></div>

    <div class="animate-hero-fade-in relative mx-auto max-w-6xl">
        <div class="flex flex-col items-center text-center">
            <!-- Badge — links to the changelog for the latest version. -->
            <a
                href={changelogHref}
                class="group mb-8 inline-flex items-center gap-2 rounded-full border border-border bg-card px-4 py-2 shadow-sm transition-colors hover:border-brand/60"
            >
                <Icon name="sparkle" class="h-4 w-4 text-brand" />
                <span class="text-sm text-foreground/80">
                    {t('go.badge', { version: DOWNLOAD_VERSION })}
                </span>
                <span class="text-muted-foreground transition-transform group-hover:translate-x-0.5">→</span>
            </a>

            <!-- Hero title -->
            <h1 class="font-display mb-6 text-4xl font-bold leading-[1.08] tracking-tight md:text-6xl lg:text-7xl">
                <span class="bg-gradient-to-b from-foreground via-foreground to-muted-foreground bg-clip-text text-transparent">
                    {t('go.heroTitle1')}
                </span>
                <br />
                <span class="animate-gradient bg-gradient-to-r from-[#6366f1] via-[#818cf8] to-[#a5b4fc] bg-clip-text text-transparent">
                    {t('go.heroTitle2')}
                </span>
            </h1>

            <p class="mb-10 max-w-2xl text-base leading-relaxed text-muted-foreground md:text-lg">
                {t('go.description')}
            </p>

            <!-- Download buttons -->
            <div class="mb-16 w-full max-w-2xl">
                <div class="flex w-full flex-col items-center gap-4">
                    <div class="grid w-full max-w-xl grid-cols-2 gap-2.5 sm:grid-cols-3">
                        {downloads.map((dl) => (
                            <a
                                href={dl.url}
                                download
                                class:list={[
                                    'group flex flex-col items-start gap-2.5 rounded-xl border p-3.5 transition-all duration-150',
                                    dl.featured
                                        ? 'border-indigo-500/40 bg-indigo-500/10 hover:border-indigo-400/60 hover:bg-indigo-500/15'
                                        : 'border-white/10 bg-white/[0.04] hover:border-white/20 hover:bg-white/[0.07]',
                                ]}
                            >
                                <div class:list={[
                                    'flex h-8 w-8 items-center justify-center rounded-lg',
                                    dl.featured ? 'bg-indigo-500/20 text-indigo-300' : 'bg-white/10 text-white/60',
                                ]}>
                                    {dl.platform === 'Windows' ? (
                                        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
                                            <path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/>
                                        </svg>
                                    ) : (
                                        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
                                            <path d="M12.504 0c-.155 0-.315.008-.481.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a.424.424 0 00-.04.001c-.17.35-.247.783-.226 1.229.021.47.112.962.303 1.479.402 1.094 1.218 2.227 2.462 2.799.464 1.415 1.485 2.299 2.686 2.299.85 0 1.64-.406 2.246-1.084.94.15 1.985.044 3.015-.287 1.049.293 2.046.424 2.94.305.873.975 1.918 1.066 2.789 1.066 1.162 0 2.17-.843 2.64-2.188.98-.438 1.763-1.355 2.183-2.449.453-1.178.44-2.516-.18-3.631.055-.188.08-.381.046-.575l-.007-.036c.126-.787-.014-1.638-.3-2.479-.59-1.77-1.83-3.469-2.714-4.519-.756-1.067-.975-1.928-1.05-3.02-.066-1.49 1.055-5.965-3.17-6.298-.166-.014-.326-.02-.48-.02z"/>
                                        </svg>
                                    )}
                                </div>
                                <div class="flex w-full items-end justify-between gap-1">
                                    <div>
                                        <div class:list={[
                                            'text-sm font-semibold leading-tight',
                                            dl.featured ? 'text-white' : 'text-white/80',
                                        ]}>
                                            {dl.platform}
                                        </div>
                                        <div class="mt-0.5 text-xs leading-tight text-white/40">
                                            {dl.sublabel}
                                        </div>
                                    </div>
                                    <Icon name="download-simple" class:list={[
                                        'mb-0.5 h-3.5 w-3.5 shrink-0 transition-transform group-hover:translate-y-0.5',
                                        dl.featured ? 'text-indigo-400' : 'text-white/30',
                                    ]} />
                                </div>
                            </a>
                        ))}
                    </div>
                    <p class="text-xs text-muted-foreground">
                        {currentVersionText} ·{' '}
                        <a href={changelogHref} class="underline underline-offset-2 transition-colors hover:text-foreground">
                            {lang === 'zh' ? '更新日志' : "What's new"}
                        </a>{' '}
                        ·{' '}
                        <a href="https://github.com/microblue/myclaw-desktop-releases/releases" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 transition-colors hover:text-foreground">
                            {t('go.allReleases')}
                        </a>
                    </p>
                </div>
            </div>

            <!-- Stats row -->
            <div class="grid grid-cols-2 gap-6 text-center md:flex md:items-center md:gap-16">
                {stats.map((stat, index) => (
                    <div class="contents">
                        {index > 0 && <div class="hidden h-12 w-px bg-muted md:block" />}
                        <div>
                            <div class="font-display text-3xl font-bold text-foreground md:text-4xl">{stat.value}</div>
                            <div class="text-sm text-muted-foreground">{stat.label}</div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>

<!-- What's new in latest release -->
<section class="relative border-t border-border px-6 py-20">
    <div class="relative mx-auto max-w-3xl">
        <div class="rounded-2xl border border-brand/20 bg-gradient-to-br from-brand/[0.08] to-transparent p-8">
            <div class="flex items-center justify-between gap-4 flex-wrap">
                <div>
                    <div class="mb-2 flex items-center gap-2">
                        <span class="inline-flex items-center rounded-full bg-brand/20 px-2.5 py-0.5 text-xs font-semibold text-brand">
                            {lang === 'zh' ? '新版本' : 'NEW'}
                        </span>
                        <span class="text-sm text-muted-foreground">
                            {new Intl.DateTimeFormat(
                                lang === 'zh' ? 'zh-CN' : 'en-US',
                                { year: 'numeric', month: 'long', day: 'numeric' },
                            ).format(new Date(LATEST.date))}
                        </span>
                    </div>
                    <h2 class="font-display text-2xl font-bold text-foreground">
                        {lang === 'zh' ? 'v' : "What's new in v"}{LATEST.version}{lang === 'zh' ? ' 有什么新内容' : ''}
                    </h2>
                </div>
                <a
                    href={changelogHref}
                    class="text-sm font-medium text-brand underline underline-offset-4 hover:text-brand-light"
                >
                    {lang === 'zh' ? '查看所有版本更新' : 'View all releases'} →
                </a>
            </div>

            <ul class="mt-6 space-y-2.5">
                {latestHighlights.map((change) => (
                    <li class="flex gap-3">
                        <Icon name="sparkle" class="mt-0.5 h-4 w-4 shrink-0 text-brand" />
                        <span
                            class="text-sm leading-relaxed text-muted-foreground"
                            set:html={change.text.replace(
                                /`([^`]+)`/g,
                                '<code class="rounded bg-white/10 px-1.5 py-0.5 text-[0.85em] text-foreground">$1</code>'
                            )}
                        />
                    </li>
                ))}
            </ul>
        </div>
    </div>
</section>

<!-- Features -->
<section id="features" class="relative scroll-mt-24 border-t border-border px-6 py-24">
    <div class="mx-auto max-w-6xl">
        <div class="mb-16 text-center">
            <span class="mb-4 inline-flex items-center rounded-full border border-border bg-card px-3 py-1 text-xs font-medium text-foreground/80 shadow-sm">
                {t('go.features')}
            </span>
            <h2 class="font-display mb-4 bg-gradient-to-b from-foreground to-muted-foreground bg-clip-text text-4xl font-bold text-transparent md:text-5xl">
                {t('go.whyMyClawGo')}
            </h2>
            <p class="mx-auto max-w-xl text-lg text-muted-foreground">
                {t('go.featuresDescription')}
            </p>
        </div>

        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
            {features.map((feature) => (
                <div class="rounded-xl border border-border bg-white/[0.02] p-6">
                    <Icon name={feature.icon as any} class="mb-4 h-8 w-8 text-indigo-400" />
                    <h3 class="font-display mb-2 text-lg font-semibold text-foreground">
                        {feature.title}
                    </h3>
                    <p class="text-sm leading-relaxed text-muted-foreground">
                        {feature.description}
                    </p>
                </div>
            ))}
        </div>
    </div>
</section>

<!-- Comparison table -->
<section id="comparison" class="relative scroll-mt-24 border-t border-border px-6 py-24">
    <div class="mx-auto max-w-3xl">
        <div class="mb-16 text-center">
            <span class="mb-4 inline-flex items-center rounded-full border border-border bg-card px-3 py-1 text-xs font-medium text-foreground/80 shadow-sm">
                {t('go.comparison')}
            </span>
            <h2 class="font-display mb-4 bg-gradient-to-b from-foreground to-muted-foreground bg-clip-text text-4xl font-bold text-transparent md:text-5xl">
                {t('go.comparisonTitle')}
            </h2>
            <p class="mx-auto max-w-xl text-lg text-muted-foreground">
                {t('go.comparisonDescription')}
            </p>
        </div>

        <div class="overflow-hidden rounded-xl border border-border">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-border bg-white/[0.02]">
                        <th class="px-6 py-4">
                            <div class="flex items-center justify-center gap-2">
                                <span class="font-display text-base font-bold text-foreground">
                                    {t('common.brandName')} Desktop
                                </span>
                            </div>
                        </th>
                        <th class="px-6 py-4 text-center">
                            <span class="font-medium text-muted-foreground">
                                {t('landing.others')}
                            </span>
                        </th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border">
                    {comparisonRows.map((row, index) => (
                        <tr class:list={[index % 2 !== 0 ? 'bg-white/[0.01]' : '']}>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <Icon name="check" class="h-5 w-5 flex-shrink-0 text-green-400" />
                                    <span class="text-foreground">{row.us}</span>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <Icon name="x" class="h-5 w-5 flex-shrink-0 text-red-400" />
                                    <span class="text-muted-foreground">{row.others}</span>
                                </div>
                            </td>
                        </tr>
                    ))}
                </tbody>
            </table>
        </div>
    </div>
</section>

<!-- FAQ -->
<section id="faq" class="relative scroll-mt-24 border-t border-border px-6 py-24">
    <div class="mx-auto max-w-3xl">
        <div class="mb-16 text-center">
            <span class="mb-4 inline-flex items-center rounded-full border border-border bg-card px-3 py-1 text-xs font-medium text-foreground/80 shadow-sm">
                {t('go.faqTitle')}
            </span>
            <h2 class="font-display mb-4 bg-gradient-to-b from-foreground to-muted-foreground bg-clip-text text-4xl font-bold text-transparent md:text-5xl">
                {t('go.faqHeading')}
            </h2>
            <p class="mx-auto max-w-xl text-lg text-muted-foreground">
                {t('go.faqDescription')}
            </p>
        </div>

        <div class="space-y-3">
            {faqs.map((faq) => (
                <details class="group overflow-hidden rounded-xl border border-border bg-white/[0.02]">
                    <summary class="flex w-full cursor-pointer items-center justify-between p-5 text-left transition-colors hover:bg-white/[0.04] [&::-webkit-details-marker]:hidden">
                        <span class="pr-4 font-medium text-foreground">{faq.question}</span>
                        <Icon name="caret-down" class="h-5 w-5 flex-shrink-0 text-muted-foreground transition-transform duration-200 group-open:rotate-180" />
                    </summary>
                    <div class="px-5 pb-5">
                        <p class="leading-relaxed text-muted-foreground">{faq.answer}</p>
                    </div>
                </details>
            ))}
        </div>
    </div>
</section>

<!-- CTA -->
<section class="relative border-t border-border px-6 py-32">
    <div class="mx-auto max-w-4xl text-center">
        <div class="rounded-2xl border border-border/50 bg-gradient-to-b from-white/[0.03] to-transparent px-6 py-12">
            <h2 class="font-display mb-4 text-3xl font-bold">{t('go.ctaTitle')}</h2>
            <p class="mx-auto mb-8 max-w-xl text-base text-muted-foreground">
                {t('go.ctaDescription')}
            </p>
            <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
                <a
                    href={downloads[0].url}
                    download
                    class="inline-flex items-center gap-2 rounded-xl bg-indigo-600 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-indigo-500"
                >
                    <Icon name="download-simple" class="h-4 w-4" />
                    {t('go.download', { os: 'Windows' })}
                </a>
            </div>
        </div>
    </div>
</section>
