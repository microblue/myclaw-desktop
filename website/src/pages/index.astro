---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout
  title="MyClaw.One Desktop — Your Personal AI Command Center"
  description="Install MyClaw.One on macOS, Linux, or Windows. Own your AI agents, your data, your workflows."
  lang="en"
  canonicalPath="/"
>
  <section class="mx-auto max-w-6xl px-4 py-20 text-center">
    <h1 class="text-5xl font-bold tracking-tight sm:text-6xl">
      MyClaw.One Desktop
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600">
      [Phase 2 placeholder] Port of Desktop.tsx lands in Phase 4.
    </p>
    <p class="mt-10 text-sm text-gray-400">
      Build toolchain: Astro + Tailwind · i18n via @openclaw/i18n (vendored).
    </p>
  </section>
</BaseLayout>
