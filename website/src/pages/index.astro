---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { setLanguage, t } from '@/lib/i18n';

setLanguage('en');
---
<BaseLayout
  title={t('go.pageTitle')}
  description={t('go.description')}
  lang="en"
  canonicalPath="/"
>
  <section class="mx-auto max-w-6xl px-4 py-20 text-center">
    <h1 class="text-5xl font-bold tracking-tight sm:text-6xl">
      {t('go.heroTitle1')}<br />{t('go.heroTitle2')}
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600">
      {t('go.description')}
    </p>
    <p class="mt-10 text-sm text-gray-400">
      Phase 3 verification — i18n rendering live at build time.
    </p>
  </section>
</BaseLayout>
